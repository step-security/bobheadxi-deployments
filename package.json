{
  "name": "@step-security/deployments",
  "version": "1.5.0",
  "private": true,
  "description": "GitHub Action for working painlessly with deployment statuses",
  "main": "dist/index.js",
  "scripts": {
    "prettier": "prettier src --write",
    "prettier:check": "prettier src --check",
    "build": "ncc build src/main.ts --out dist --minify --source-map --license LICENSES",
    "build:check": "npm run build && git diff --quiet dist",
    "test": "npm run prettier:check & npm run build:check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/bobheadxi-deployments.git"
  },
  "author": "step-security",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "2.0.1",
    "@actions/github": "9.1.1",
    "axios": "1.16.0"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.5",
    "@types/node": "18.11.18",
    "@vercel/ncc": "^0.38.4",
    "prettier": "2.8.3",
    "typescript": "4.9.4"
  }
}
